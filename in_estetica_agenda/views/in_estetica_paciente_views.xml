<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_estetica_paciente_list" model="ir.ui.view">
        <field name="name">in_estetica.paciente.list</field>
        <field name="model">in_estetica.paciente</field>
        <field name="arch" type="xml">
            <list string="Pacientes" sample="1">
                <field name="ref_paciente"/>
                <field name="name"/>
                <field name="vat" string="Cédula"/>
                <field name="edad"/>
                <field name="genero"/>
                <field name="phone" optional="show"/>
                <field name="mobile" optional="show"/>
                <field name="email" optional="show"/>
                <field name="fototipo" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_in_estetica_paciente_form" model="ir.ui.view">
        <field name="name">in_estetica.paciente.form</field>
        <field name="model">in_estetica.paciente</field>
        <field name="arch" type="xml">
            <form string="Paciente">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name" string="Nombre" class="oe_edit_only"/>
                        <h1>
                            <field name="name" required="1"
                                   placeholder="Nombre y apellido"/>
                        </h1>
                        <field name="ref_paciente" readonly="1"/>
                    </div>
                    <group>
                        <group string="Identificación">
                            <label for="vat" string="Cédula"/>
                            <field name="vat" nolabel="1" placeholder="10 dígitos"/>
                            <field name="fecha_nacimiento"/>
                            <field name="edad"/>
                            <field name="genero" widget="radio"
                                   options="{'horizontal': true}"/>
                            <field name="estado_civil"/>
                            <field name="ocupacion"/>
                            <field name="fototipo"/>
                        </group>
                        <group string="Contacto">
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>
                    <group string="Dirección">
                        <label for="street" string="Domicilio"/>
                        <div class="o_address_format">
                            <field name="street" placeholder="Calle..."
                                   class="o_address_street"/>
                            <field name="street2" placeholder="Calle 2..."
                                   class="o_address_street"/>
                            <field name="city" placeholder="Ciudad"
                                   class="o_address_city"/>
                            <field name="state_id" class="o_address_state"
                                   placeholder="Provincia"
                                   options="{'no_open': True, 'no_quick_create': True}"/>
                            <field name="zip" placeholder="C.P."
                                   class="o_address_zip"/>
                            <field name="country_id"
                                   placeholder="País" class="o_address_country"
                                   options="{'no_open': True, 'no_create': True}"/>
                        </div>
                    </group>
                    <notebook>
                        <page string="Antecedentes" name="antecedentes">
                            <group>
                                <field name="antecedentes"
                                       placeholder="Enfermedades o condiciones relevantes (diabetes, hipertensión, embarazo/lactancia...)"/>
                                <field name="alergias"
                                       placeholder="Alergias a medicamentos, anestésicos, productos..."/>
                                <field name="medicacion_actual"
                                       placeholder="Fármacos que toma habitualmente"/>
                                <field name="cirugias"
                                       placeholder="Cirugías o procedimientos previos"/>
                            </group>
                        </page>
                        <page string="Notas" name="notas">
                            <field name="notas" nolabel="1"
                                   placeholder="Notas internas sobre el paciente"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_in_estetica_paciente_search" model="ir.ui.view">
        <field name="name">in_estetica.paciente.search</field>
        <field name="model">in_estetica.paciente</field>
        <field name="arch" type="xml">
            <search string="Buscar pacientes">
                <field name="name"/>
                <field name="vat" string="Cédula"/>
                <field name="ref_paciente"/>
                <field name="phone"/>
                <field name="email"/>
                <separator/>
                <filter string="Femenino" name="filter_femenino"
                        domain="[('genero', '=', 'femenino')]"/>
                <filter string="Masculino" name="filter_masculino"
                        domain="[('genero', '=', 'masculino')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Género" name="group_genero"
                            context="{'group_by': 'genero'}"/>
                    <filter string="Fototipo" name="group_fototipo"
                            context="{'group_by': 'fototipo'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_paciente" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="res_model">in_estetica.paciente</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_in_estetica_paciente_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aún no hay pacientes registrados</p>
            <p>Usá <strong>Nuevo</strong> para dar de alta un paciente del centro.</p>
        </field>
    </record>

</odoo>
