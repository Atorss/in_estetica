<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_planificacion" model="ir.sequence">
            <field name="name">Planificación de horarios</field>
            <field name="code">in_estetica.planificacion</field>
            <field name="prefix">PLAN/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_turno" model="ir.sequence">
            <field name="name">Turno</field>
            <field name="code">in_estetica.turno</field>
            <field name="prefix">TUR/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_paciente" model="ir.sequence">
            <field name="name">Paciente</field>
            <field name="code">in_estetica.paciente</field>
            <field name="prefix">PAC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

    </data>
</odoo>
