<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Engancha el menú raíz "Administración" al grupo MUK
            "Administración Estética" de la sidebar.
            El record vive en muk_web_appsbar/data/menu_groups_demo.xml
            (xmlid: menu_group_medic_administracion).

            Usamos comando (4, id) aditivo. Como en in_estetica_control,
            un post_init_hook reaplica la asociación porque el eval con
            record de otro módulo no persiste de forma confiable en Odoo 18.
        -->
        <record id="muk_web_appsbar.menu_group_medic_administracion" model="ir.ui.menu.group">
            <field name="menu_ids" eval="[
                (4, ref('in_estetica_core.menu_in_estetica_core_root')),
            ]"/>
        </record>

    </data>
</odoo>
