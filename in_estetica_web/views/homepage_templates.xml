<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- HEAD: Google Fonts (Fraunces display + Inter body)           -->
    <!-- ============================================================ -->
    <template id="estetica_fonts" name="Estetica - Google Fonts" inherit_id="website.layout" customize_show="True">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
            <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&amp;family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- BRAND: Wordmark RENOVA en el navbar                          -->
    <!-- ============================================================ -->
    <template id="estetica_brand" name="Estetica - Wordmark" inherit_id="website.option_header_brand_logo" customize_show="True">
        <xpath expr="//a[@data-name='Navbar Logo']" position="replace">
            <a data-name="Navbar Logo" href="/" t-attf-class="navbar-brand logo wobbe-brand #{_link_class}">
                <span class="wobbe-brand__text">
                    RENOVA<span class="wobbe-brand__sub">Medicina Estetica</span>
                </span>
            </a>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- HOMEPAGE                                                     -->
    <!-- ============================================================ -->
