<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inyecta Google Fonts (Playfair + Inter) en el <head> del backend -->
    <template id="wobbe_backend_fonts" name="Wobbe Backend Fonts" inherit_id="web.layout">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
            <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&amp;family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

</odoo>
