<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_estetica_control_recarga_ia_list" model="ir.ui.view">
        <field name="name">in_estetica_control.recarga_ia.list</field>
        <field name="model">in_estetica_control.recarga_ia</field>
        <field name="arch" type="xml">
            <list string="Recargas IA"
                  decoration-success="state == 'vigente'"
                  decoration-muted="state == 'agotada'">
                <field name="fecha"/>
                <field name="suscripcion_id"/>
                <field name="company_id"/>
                <field name="monto_cobrado_usd" sum="Total cobrado"/>
                <field name="margen_pct_aplicado" optional="hide"
                       groups="in_estetica_control.group_innatum_admin"/>
                <field name="tokens_disponibles_usd"
                       groups="in_estetica_control.group_innatum_admin"/>
                <field name="tokens_consumidos_usd"
                       groups="in_estetica_control.group_innatum_admin"/>
                <field name="tokens_restantes_usd"
                       groups="in_estetica_control.group_innatum_admin"/>
                <field name="consumido_visible_usd" string="Consumido (USD)"/>
                <field name="restante_visible_usd" string="Restante (USD)"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'vigente'"
                       decoration-muted="state == 'agotada'"/>
            </list>
        </field>
    </record>

    <record id="view_in_estetica_control_recarga_ia_form" model="ir.ui.view">
        <field name="name">in_estetica_control.recarga_ia.form</field>
        <field name="model">in_estetica_control.recarga_ia</field>
        <field name="arch" type="xml">
            <form string="Recarga IA">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Recarga">
                            <field name="suscripcion_id"
                                   options="{'no_create': True}"/>
                            <field name="company_id" readonly="1"/>
                            <field name="fecha"/>
                            <field name="monto_cobrado_usd"/>
                        </group>
                        <group string="Saldo">
                            <field name="margen_pct_aplicado" readonly="1"
                                   groups="in_estetica_control.group_innatum_admin"/>
                            <field name="tokens_disponibles_usd"
                                   groups="in_estetica_control.group_innatum_admin"/>
                            <field name="tokens_consumidos_usd"
                                   groups="in_estetica_control.group_innatum_admin"/>
                            <field name="tokens_restantes_usd"
                                   groups="in_estetica_control.group_innatum_admin"/>
                            <field name="consumido_visible_usd"
                                   string="Consumido (USD)"/>
                            <field name="restante_visible_usd"
                                   string="Restante (USD)"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'vigente'"
                                   decoration-muted="state == 'agotada'"/>
                        </group>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1"
                               placeholder="Referencia del pago, # de transferencia, etc."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_in_estetica_control_recarga_ia" model="ir.actions.act_window">
        <field name="name">Recargas IA</field>
        <field name="res_model">in_estetica_control.recarga_ia</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
