<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Wiring de menús al grupo "Innatum" de la sidebar MUK.
            El grupo en sí se define en muk_web_appsbar/data/menu_groups_demo.xml
            (junto a Administración y Gestion Financiera).

            Este archivo solo asocia los menús que viven en el grupo:
            - AI Assistant (innatum_ai)
            - Settings, Apps (base) — uso restringido a base.group_system.
        -->
        <record id="muk_web_appsbar.menu_group_innatum" model="ir.ui.menu.group">
            <field name="menu_ids" eval="[
                (4, ref('innatum_ai.menu_ai_assistant_root')),
                (4, ref('base.menu_administration')),
                (4, ref('base.menu_management')),
            ]"/>
        </record>

    </data>
</odoo>
