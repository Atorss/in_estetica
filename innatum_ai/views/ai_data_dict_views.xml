<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Data Dictionary Form -->
    <record id="view_ai_data_dict_form" model="ir.ui.view">
        <field name="name">innatum.ai.data.dict.form</field>
        <field name="model">innatum.ai.data.dict</field>
        <field name="arch" type="xml">
            <form duplicate="0" string="Diccionario de Datos">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Alias (ej: Paciente, Empleado, Factura)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_name" placeholder="ej: res.partner"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Campos principales (nombre:tipo:descripción)">
                        <field name="key_fields" nolabel="1" colspan="2"
                               placeholder="name:char:Nombre del paciente&#10;gender:selection:Género [male,female]&#10;age:integer:Edad"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Data Dictionary List -->
    <record id="view_ai_data_dict_list" model="ir.ui.view">
        <field name="name">innatum.ai.data.dict.list</field>
        <field name="model">innatum.ai.data.dict</field>
        <field name="arch" type="xml">
            <list duplicate="0" string="Diccionario de Datos">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Data Dictionary Action -->
    <record id="action_ai_data_dict" model="ir.actions.act_window">
        <field name="name">Diccionario de Datos</field>
        <field name="res_model">innatum.ai.data.dict</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Server Action: Auto-generate dictionary -->
    <record id="action_auto_generate_dict" model="ir.actions.server">
        <field name="name">Auto-generar Diccionario</field>
        <field name="model_id" ref="model_innatum_ai_data_dict"/>
        <field name="state">code</field>
        <field name="code">action = env['innatum.ai.data.dict'].auto_generate_all()</field>
    </record>

</odoo>
