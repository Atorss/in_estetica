<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Provider Form View -->
    <record id="view_ai_provider_form" model="ir.ui.view">
        <field name="name">innatum.ai.provider.form</field>
        <field name="model">innatum.ai.provider</field>
        <field name="arch" type="xml">
            <form duplicate="0" string="Proveedor de IA">
                <header>
                    <button name="test_connection" type="object" string="Probar Conexión" class="btn-primary" icon="fa-plug"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(innatum_ai.action_ai_conversation_list)d" type="action"
                                class="oe_stat_button" icon="fa-comments">
                            <field name="conversation_ids" widget="statinfo" string="Conversaciones"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Por Defecto" bg_color="text-bg-success"
                            invisible="not is_default"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del proveedor"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuración">
                            <field name="provider_type"/>
                            <field name="model_id_name"/>
                            <field name="custom_model" placeholder="Solo si tu modelo no está en la lista"/>
                            <field name="api_key" password="True"/>
                            <field name="api_base_url" placeholder="Dejar vacío para URL por defecto"/>
                        </group>
                        <group string="Parámetros">
                            <field name="max_tokens"/>
                            <field name="temperature"/>
                            <field name="is_default"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Prompt del Sistema">
                        <field name="system_prompt" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Provider List View -->
    <record id="view_ai_provider_list" model="ir.ui.view">
        <field name="name">innatum.ai.provider.list</field>
        <field name="model">innatum.ai.provider</field>
        <field name="arch" type="xml">
            <list duplicate="0" string="Proveedores de IA">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="provider_type"/>
                <field name="model_id_name"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Provider Action -->
    <record id="action_ai_provider" model="ir.actions.act_window">
        <field name="name">Proveedores de IA</field>
        <field name="res_model">innatum.ai.provider</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configura tu primer proveedor de IA
            </p>
            <p>
                Agrega las credenciales de Claude (Anthropic), OpenAI o Google Gemini.
            </p>
        </field>
    </record>

    <!-- AI Tool Form View -->
    <record id="view_ai_tool_form" model="ir.ui.view">
        <field name="name">innatum.ai.tool.form</field>
        <field name="model">innatum.ai.tool</field>
        <field name="arch" type="xml">
            <form duplicate="0" string="Herramienta de IA">
                <sheet>
                    <div class="oe_title">
                        <label for="display_name_field"/>
                        <h1>
                            <field name="display_name_field"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tool_type"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="allowed_models" placeholder="res.partner,sale.order (vacío = todos)"/>
                            <field name="requires_confirmation"/>
                            <field name="group_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Descripción para la IA">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- AI Tool List View -->
    <record id="view_ai_tool_list" model="ir.ui.view">
        <field name="name">innatum.ai.tool.list</field>
        <field name="model">innatum.ai.tool</field>
        <field name="arch" type="xml">
            <list duplicate="0" string="Herramientas de IA">
                <field name="sequence" widget="handle"/>
                <field name="display_name_field"/>
                <field name="name"/>
                <field name="tool_type"/>
                <field name="allowed_models"/>
                <field name="requires_confirmation"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- AI Tool Action -->
    <record id="action_ai_tool" model="ir.actions.act_window">
        <field name="name">Herramientas de IA</field>
        <field name="res_model">innatum.ai.tool</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
