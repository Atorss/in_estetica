<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Conversation Form View -->
    <record id="view_ai_conversation_form" model="ir.ui.view">
        <field name="name">innatum.ai.conversation.form</field>
        <field name="model">innatum.ai.conversation</field>
        <field name="arch" type="xml">
            <form duplicate="0" string="Conversación IA">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="provider_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="message_count"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <group string="Consumo de Tokens">
                        <group>
                            <field name="total_input_tokens"/>
                            <field name="total_output_tokens"/>
                        </group>
                        <group>
                            <field name="total_tokens"/>
                            <field name="total_api_calls"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mensajes">
                            <field name="message_ids">
                                <list duplicate="0" string="Mensajes" create="0" edit="0">
                                    <field name="sequence"/>
                                    <field name="role"/>
                                    <field name="content" widget="text"/>
                                    <field name="input_tokens"/>
                                    <field name="output_tokens"/>
                                    <field name="total_tokens"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Conversation List View -->
    <record id="view_ai_conversation_list" model="ir.ui.view">
        <field name="name">innatum.ai.conversation.list</field>
        <field name="model">innatum.ai.conversation</field>
        <field name="arch" type="xml">
            <list duplicate="0" string="Conversaciones IA">
                <field name="name"/>
                <field name="provider_id"/>
                <field name="user_id"/>
                <field name="message_count"/>
                <field name="total_tokens"/>
                <field name="total_api_calls"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Conversation Action -->
    <record id="action_ai_conversation_list" model="ir.actions.act_window">
        <field name="name">Conversaciones IA</field>
        <field name="res_model">innatum.ai.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
    </record>

</odoo>
