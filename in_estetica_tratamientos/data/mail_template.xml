<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_recordatorio_sesion" model="mail.template">
            <field name="name">Recordatorio de próxima sesión</field>
            <field name="model_id" ref="model_in_estetica_tratamiento"/>
            <field name="subject">Tu próxima sesión de {{ object.tipo_tratamiento_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.paciente_id.email }}</field>
            <field name="lang">{{ object.paciente_id.lang or 'es_EC' }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Inter, Arial, sans-serif; color: #2b1a2e; max-width: 560px; margin: auto;">
                    <p>Hola <t t-out="object.paciente_id.name or ''"/>,</p>
                    <p t-if="object.proxima_es_retoque">
                        Te recordamos que ya es momento de tu <strong>retoque</strong> de
                        <strong t-out="object.tipo_tratamiento_id.name or ''"/>.
                    </p>
                    <p t-else="">
                        Te recordamos que se acerca tu próxima sesión
                        (<t t-out="object.sesiones_realizadas + 1"/> de <t t-out="object.sesiones_totales"/>)
                        de <strong t-out="object.tipo_tratamiento_id.name or ''"/>.
                    </p>
                    <p>
                        Fecha sugerida:
                        <strong t-out="object.proxima_sesion_fecha"/>.
                    </p>
                    <p>Comunícate con nosotros para confirmar tu cita. ¡Te esperamos!</p>
                    <p style="color:#b63a6c; font-weight:600;">RENOVA · Medicina Estética</p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>
