<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="tipo_botox" model="in_estetica.tipo_tratamiento">
            <field name="name">Botox (Toxina botulínica)</field>
            <field name="sequence">10</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">1</field>
            <field name="intervalo_valor">2</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="requiere_retoque" eval="True"/>
            <field name="retoque_valor">4</field>
            <field name="retoque_unidad">meses</field>
            <field name="color">2</field>
            <field name="descripcion">Suaviza arrugas de expresión. Retoque cada 4 meses aprox.</field>
        </record>

        <record id="tipo_acido_hialuronico" model="in_estetica.tipo_tratamiento">
            <field name="name">Ácido hialurónico</field>
            <field name="sequence">20</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">1</field>
            <field name="requiere_retoque" eval="True"/>
            <field name="retoque_valor">12</field>
            <field name="retoque_unidad">meses</field>
            <field name="color">3</field>
            <field name="descripcion">Volumen e hidratación. Reposición cada 9-12 meses.</field>
        </record>

        <record id="tipo_exosomas" model="in_estetica.tipo_tratamiento">
            <field name="name">Exosomas</field>
            <field name="sequence">30</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">3</field>
            <field name="intervalo_valor">3</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">4</field>
            <field name="descripcion">Regeneración celular. Protocolo de 3 sesiones.</field>
        </record>

        <record id="tipo_celulas_madre" model="in_estetica.tipo_tratamiento">
            <field name="name">Células madre</field>
            <field name="sequence">40</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">3</field>
            <field name="intervalo_valor">4</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">5</field>
            <field name="descripcion">Bioregeneración. Protocolo de 3 sesiones.</field>
        </record>

        <record id="tipo_pdrn" model="in_estetica.tipo_tratamiento">
            <field name="name">PDRN</field>
            <field name="sequence">50</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">4</field>
            <field name="intervalo_valor">2</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">6</field>
            <field name="descripcion">Rejuvenecimiento y reparación. 4 sesiones cada 2 semanas.</field>
        </record>

        <record id="tipo_exilis" model="in_estetica.tipo_tratamiento">
            <field name="name">Exilis</field>
            <field name="sequence">60</field>
            <field name="categoria">corporal</field>
            <field name="sesiones_recomendadas">6</field>
            <field name="intervalo_valor">1</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">7</field>
            <field name="descripcion">Radiofrecuencia para firmeza y reducción. 6 sesiones semanales.</field>
        </record>

        <record id="tipo_laser" model="in_estetica.tipo_tratamiento">
            <field name="name">Láser</field>
            <field name="sequence">70</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">6</field>
            <field name="intervalo_valor">4</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">8</field>
            <field name="descripcion">Depilación, manchas y fotorejuvenecimiento. 6 sesiones.</field>
        </record>

        <record id="tipo_limpieza_facial" model="in_estetica.tipo_tratamiento">
            <field name="name">Limpieza facial</field>
            <field name="sequence">80</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">1</field>
            <field name="requiere_retoque" eval="True"/>
            <field name="retoque_valor">1</field>
            <field name="retoque_unidad">meses</field>
            <field name="color">9</field>
            <field name="descripcion">Higiene facial profunda. Mantenimiento mensual.</field>
        </record>

        <record id="tipo_fototerapia" model="in_estetica.tipo_tratamiento">
            <field name="name">Fototerapia</field>
            <field name="sequence">90</field>
            <field name="categoria">facial</field>
            <field name="sesiones_recomendadas">8</field>
            <field name="intervalo_valor">1</field>
            <field name="intervalo_unidad">semanas</field>
            <field name="color">1</field>
            <field name="descripcion">Tratamiento con luz LED. Protocolo de 8 sesiones semanales.</field>
        </record>

    </data>
</odoo>
