<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wizard_agregar_sesiones_form" model="ir.ui.view">
        <field name="name">in_estetica.wizard_agregar_sesiones.form</field>
        <field name="model">in_estetica.wizard_agregar_sesiones</field>
        <field name="arch" type="xml">
            <form string="Agregar más sesiones">
                <field name="tratamiento_id" invisible="1"/>
                <group>
                    <field name="progreso_actual"/>
                    <field name="cantidad"/>
                </group>
                <div class="alert alert-info" role="alert">
                    Se sumarán las sesiones al total y el tratamiento volverá a
                    estado "En curso".
                </div>
                <footer>
                    <button name="action_confirmar" type="object"
                            string="Agregar sesiones" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
